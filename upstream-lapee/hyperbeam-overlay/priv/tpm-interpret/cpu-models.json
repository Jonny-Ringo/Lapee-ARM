    "tee-feature-map": {
        "SME":     "AMD Secure Memory Encryption (whole-RAM via single key)",
        "SEV":     "AMD Secure Encrypted Virtualization (per-VM keys, pre-Milan)",
        "SEV-ES":  "SEV with Encrypted State (register encryption on VMEXIT)",
        "SEV-SNP": "SEV with Secure Nested Paging (integrity + RMP; required for paper §Arch confidential-compute fallback)",
        "TME":     "Intel Total Memory Encryption (single-key; the paper §Arch line 226 baseline)",
        "TME-MK":  "Intel TME Multi-Key (per-tenant keys; pre-req for TDX)",
        "TDX":     "Intel Trust Domain Extensions (CVM-equivalent, CCEL log)",
        "TXT":     "Intel Trusted Execution Technology (late-launch via SINIT)",
        "SGX":     "Intel Software Guard Extensions (enclaves)",
        "CET":     "Control-flow Enforcement Technology (shadow stack + IBT)",
        "TDT":     "Intel Thread Director Telemetry",
        "AMX":     "Intel Advanced Matrix Extensions (BF16/INT8 tile accelerator)",
        "MPX":     "Intel Memory Protection Extensions (deprecated)"
    },
    "source": "Intel SDM Volume 4 §Table 2-8 (CPUID family/model) + AMD PPR for AMD Family 17h/19h/1Ah Models + public product pages. Cross-referenced against Linux kernel arch/x86/include/asm/intel-family.h."
