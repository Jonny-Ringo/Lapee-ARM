{
    "schema-version": 1,
    "name": "LapEE OS baseline IMA appraisal policy",
    "distribution": "lapee-baremetal",
    "applies-to": {
        "kernel-name-prefix": ["lapee-", "LapEE-", "LapeeOS-"],
        "uki-profile-key":    ["lapee-os-reference"]
    },
    "minimum-hash-alg": "sha256",
    "expected-files": [
        {"pathname-prefix": "/usr/bin/",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "system-binary",
         "notes": "Every userspace binary under /usr/bin must be signed by the LapEE OS signing key."},
        {"pathname-prefix": "/usr/sbin/",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "system-binary"},
        {"pathname-prefix": "/usr/lib/systemd/",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "system-binary",
         "notes": "systemd itself + all systemd tools."},
        {"pathname-prefix": "/usr/lib/",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "system-binary",
         "notes": "shared objects under /usr/lib must be signed."},
        {"pathname-suffix": ".ko",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "module",
         "notes": "Linux kernel modules require module-signing enforcement."},
        {"pathname-suffix": ".ko.xz",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "module"},
        {"pathname-prefix": "/etc/",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "config",
         "notes": "Config files are measured but not required to be signed; changes produce an audit trail."},
        {"pathname": "boot_aggregate",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "other",
         "notes": "IMA's synthetic boot_aggregate — aggregate of PCR 0-9."}
    ],
    "notes": "LapEE OS enforces strict IMA appraisal for all system binaries. Any /usr/bin binary without a matching EVM signature is a policy violation. /etc/ files are measured for audit but unsigned changes don't trigger rejection (they DO appear in the attestation).",
    "source": "lapee-baremetal/kernel-config (CONFIG_IMA_APPRAISE=y + CONFIG_IMA_APPRAISE_REQUIRE_SIGNATURES=y)"
}
