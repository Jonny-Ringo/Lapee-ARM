{
    "schema-version": 1,
    "name": "Debian 12+ baseline IMA policy (when enabled)",
    "distribution": "Debian GNU/Linux",
    "applies-to": {
        "kernel-name-prefix": ["Debian", "debian-"],
        "uki-profile-key":    ["debian-systemd-stub-baseline"]
    },
    "minimum-hash-alg": "sha256",
    "expected-files": [
        {"pathname-prefix": "/usr/bin/",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "system-binary"},
        {"pathname-prefix": "/usr/sbin/",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "system-binary"},
        {"pathname-prefix": "/lib/modules/",
         "signature-required": true,
         "hash-alg": "sha256",
         "category": "module",
         "notes": "Debian kernel modules must be signed by Debian's secure-boot CA when Secure Boot is on."},
        {"pathname-prefix": "/etc/",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "config"},
        {"pathname": "boot_aggregate",
         "signature-required": false,
         "hash-alg": "sha256",
         "category": "other"}
    ],
    "notes": "Debian's stock kernel is built with CONFIG_IMA=y but ships no default IMA policy; `ima` is effectively audit-only unless the admin enables appraisal via a LSM module signal. Kernel modules are the one exception when Secure Boot is on.",
    "source": "https://www.debian.org/doc/manuals/securing-debian-manual/"
}
