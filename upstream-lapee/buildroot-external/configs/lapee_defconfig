# zstd: needed at runtime by the kernel's CONFIG_RD_ZSTD path
# (initramfs decompression) and by any operator-side tooling.
BR2_PACKAGE_ZSTD=y

# Some HyperBEAM dependencies and OTP libraries link against libgmp
# on the v1 LapEE branch. Keep the target runtime complete even when
# Buildroot's transitive dependency graph does not pull it in.
BR2_PACKAGE_GMP=y

# ----- LapEE custom packages --------------------------------
# Cross-compiles HyperBEAM (Erlang code + lapee_tpm_nif) inside
# Buildroot, against Buildroot's OTP and libtss2. Installs the
# relx release into /usr/lib/hyperbeam in the target rootfs.
BR2_PACKAGE_HYPERBEAM=y

# ----- build hygiene ----------------------------------------
BR2_REPRODUCIBLE=y
# A fixed SOURCE_DATE_EPOCH so timestamps embedded in built
# binaries are deterministic across runs. Set to 2026-01-01
# 00:00:00 UTC. Bump on a new release tag.
BR2_REPRODUCIBLE_SOURCE_DATE_EPOCH=1735689600
BR2_ENABLE_DEBUG=n
BR2_STRIP_strip=y
