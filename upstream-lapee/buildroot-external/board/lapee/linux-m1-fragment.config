# lapee linux-m1-fragment.config — merged on top of Buildroot's x86_64
# kernel defconfig. Adds every symbol the LapEE brief requires:
#
#   TPM 2.0 (TPM, TIS, CRB, HW_RANDOM_TPM)
#   Integrity + IMA
#   Lockdown LSM (built in, enforced at boot)
#   Module signing
#   EFI stub (UKI-ready)
#   DM-Verity
#   Virtio (net, block, pci, console)
#   Serial console
#
# Deliberately NOT set (attack-surface reduction): local input/HID,
# USB4/Thunderbolt, Bluetooth, sound, kernel debug escape hatches.

# --- TPM 2.0 (required) ---
CONFIG_TCG_TPM=y
CONFIG_HW_RANDOM_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_CRB=y

# --- Integrity + IMA ---
CONFIG_INTEGRITY=y
CONFIG_INTEGRITY_SIGNATURE=y
CONFIG_IMA=y
CONFIG_IMA_MEASURE_PCR_IDX=10
CONFIG_IMA_LSM_RULES=y

# --- Security / Lockdown / Module sig ---
# The lockdown level itself is set further down with
# CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y. Don't set
# CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY=y here — they're a
# Kconfig `choice', mutually exclusive, last-wins on
# olddefconfig, and a duplicate just leaves a future reader
# wondering which mode is real.
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_HASH="sha256"
CONFIG_MODULE_SIG_SHA256=y

# --- EFI stub (UKI-ready) ---
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=y
CONFIG_EFIVAR_FS=y

# --- DM-Verity (sealed rootfs) ---
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_CRYPT=y

# --- Virtio (for QEMU) ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRT_DRIVERS=y
CONFIG_VIRTIO_IOMMU=y

# --- Confidential-computing guests ---
# SNP-capable LapEE images need the in-guest SEV driver so `~snp@1.0'
# can read `/dev/sev-guest' inside an AMD SEV-SNP VM.
CONFIG_AMD_MEM_ENCRYPT=y
CONFIG_SEV_GUEST=y

# --- Wired NICs (broad real-hardware support, all built-in so
#     no module loader is needed at boot).
#
#   R8169 / MII -- Realtek RTL8111/8125 (Framework 13 native wired;
#                  also found as the chipset behind many USB-C 2.5G
#                  dongles via USB_RTL8152).
#   E1000/E1000E/IGC -- Intel 1G / 2.5G desktop + server NICs.
#   TG3 -- Broadcom NetXtreme (common on workstations + servers).
#   IXGBE -- Intel 10G (Datacenter cards, harmless on laptop image).
#
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_MII=y
CONFIG_R8169=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_IGC=y
CONFIG_IXGBE=y
CONFIG_NET_VENDOR_BROADCOM=y
#   Broadcom NetXtreme: the kernel's Kconfig symbol is `TIGON3'
#   (module name `tg3'). We use the Kconfig name here.
CONFIG_TIGON3=y

# --- USB-Ethernet dongles (four chipset families cover ~all
#     consumer / business dongles in the wild.)
#
#   USBNET -- the generic umbrella.
#   CDC_ETHER / CDC_NCM -- standards-compliant USB networking (the
#                          protocol used by Mac "Thunderbolt Bridge"
#                          and the cdc_ncm dongle class).
#   RTL8152 -- Realtek RTL8153 (most USB-C 2.5G dongles).
#   AX88179_178A / ASIX -- Asix AX88179 (most USB 3 Gigabit dongles).
#
CONFIG_USB=y
CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_USB_NET_CDC_NCM=y
CONFIG_USB_NET_CDC_MBIM=y
CONFIG_USB_NET_QMI_WWAN=y
CONFIG_USB_RTL8152=y
CONFIG_USB_NET_AX88179_178A=y
CONFIG_USB_NET_AX8817X=y
CONFIG_USB_LAN78XX=y
CONFIG_USB_NET_SMSC75XX=y
CONFIG_USB_NET_SMSC95XX=y
# iPhone-specific Ethernet-over-USB (Apple's ipheth driver). Modern
# iOS "Personal Hotspot -> USB" presents as a standard CDC-NCM device
# so CDC_NCM above usually suffices, but older iPhones / certain iOS
# versions require the dedicated ipheth driver. Including both paths
# means any iPhone plugged in via USB with Personal Hotspot enabled
# should come up as usb0 / eth0 and DHCP cleanly via the existing
# lapee-dhcp-hook. (v1.2.1 post-demo)
CONFIG_USB_IPHETH=y

# v1.2.2 paper P-arch: kernel lockdown in confidentiality mode.
# Paper section Arch specifies `lockdown=confidentiality' as the
# target posture -- denies kernel-memory disclosure paths (perf,
# kprobes, tracefs, /dev/mem read) in addition to the integrity
# restrictions. Previously deferred because HB's runtime_tools
# exercises perf via observer_cli in dev loops; on the single-
# purpose LapEE appliance we never run observer_cli interactively,
# so this is safe to enable. If an operator later needs to debug a
# crashed HB they can boot a rescue image with cmdline override,
# which will be visible in attestation as a cmdline delta (PCR 4).
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
# RNDIS is materially uglier than CDC-NCM, but many Android phones
# and some USB tether adapters still expose only RNDIS. Including it
# is an explicit compatibility choice; operators who want the smaller
# wired-only posture can build with a narrower fragment later, and the
# exact kernel image remains visible in attestation.
CONFIG_USB_NET_RNDIS_HOST=y

# --- USB4 / Thunderbolt intentionally disabled in production.
#     Hotplug buses are too powerful for the appliance posture: after
#     the ESP is read, the machine should not accept local devices.
# CONFIG_USB4 is not set
# CONFIG_USB4_NET is not set

# --- WiFi (v1.2.2).
#
# Credentials come from a strictly-validated file on the ESP
# (/EFI/boot/wifi.conf), NOT from the kernel cmdline (which would
# be baked into the UKI PE and measured into PCR 4/8 -- coupling
# boot identity to network identity + leaking the PSK via the
# event log). Userspace-side: wpa_supplicant reads a config file
# produced by the init script from the ESP data. Kernel-side: built-in
# 802.11 stack + broad internal laptop Wi-Fi coverage. This is bigger
# than the first Framework-only cut, but commodity laptop "just boots"
# support is part of the appliance promise. Extra debugfs/tracing paths
# stay disabled below.
#
#   CFG80211 + MAC80211      -- the wireless stack
#   IWLWIFI + IWLMVM/IWLDVM  -- Intel Centrino through AX/BExxx/CNVi
#   ATH10K/ATH11K/ATH12K     -- Qualcomm/Atheros QCA/WCN/QCN cards
#   BRCMFMAC/BRCMSMAC        -- Broadcom/Cypress PCIe cards
#   MT76                     -- MediaTek MT76xx/MT792x cards
#   RT2X00                   -- older Ralink PCIe cards
#   RTLWIFI/RTW88/RTW89      -- Realtek 802.11n/ac/ax/be cards
#   MWIFIEX                  -- older Marvell PCIe laptop cards
#   CFG80211_INTERNAL_REGDB -- compiled-in regulatory database so
#                              iwlwifi doesn't refuse to associate
#                              in any band above the most-
#                              conservative world regdomain (no
#                              userspace CRDA required).
CONFIG_CFG80211=y
# WEXT is the legacy Wireless Extensions ioctl API. wpa_supplicant
# uses nl80211 exclusively on any kernel >= 3.x. WEXT's ioctl
# parser has surfaced CVEs in 6.x (typically when random userspace
# can reach it). Disabled -- saves a small attack surface and
# shaves a few KB from the bzImage.
# CONFIG_CFG80211_WEXT is not set
CONFIG_CFG80211_DEFAULT_PS=n
CONFIG_MAC80211=y
CONFIG_MAC80211_RC_MINSTREL=y
CONFIG_MAC80211_RC_DEFAULT_MINSTREL=y
CONFIG_WLAN=y
CONFIG_WLAN_VENDOR_INTEL=y
CONFIG_IWLEGACY=y
CONFIG_IWL4965=y
CONFIG_IWL3945=y
# CONFIG_IWLEGACY_DEBUG is not set
# CONFIG_IWLEGACY_DEBUGFS is not set
CONFIG_IWLWIFI=y
CONFIG_IWLDVM=y
CONFIG_IWLMVM=y
# CONFIG_IWLWIFI_DEBUG is not set
# CONFIG_IWLWIFI_DEBUGFS is not set
# CONFIG_IWLWIFI_DEVICE_TRACING is not set
CONFIG_WLAN_VENDOR_ATH=y
CONFIG_ATH_COMMON=y
CONFIG_ATH5K=y
CONFIG_ATH5K_PCI=y
# CONFIG_ATH5K_DEBUG is not set
# CONFIG_ATH5K_TRACER is not set
CONFIG_ATH9K_HW=y
CONFIG_ATH9K_COMMON=y
CONFIG_ATH9K=y
CONFIG_ATH9K_PCI=y
# CONFIG_ATH9K_DEBUGFS is not set
CONFIG_ATH10K=y
CONFIG_ATH10K_PCI=y
# CONFIG_ATH10K_DEBUG is not set
# CONFIG_ATH10K_DEBUGFS is not set
# CONFIG_ATH10K_TRACING is not set
CONFIG_ATH11K=y
CONFIG_ATH11K_PCI=y
# CONFIG_ATH11K_DEBUG is not set
# CONFIG_ATH11K_DEBUGFS is not set
# CONFIG_ATH11K_TRACING is not set
CONFIG_ATH12K=y
# CONFIG_ATH12K_DEBUG is not set
# CONFIG_ATH12K_DEBUGFS is not set
# CONFIG_ATH12K_TRACING is not set
# CONFIG_ATH12K_COREDUMP is not set
CONFIG_WLAN_VENDOR_BROADCOM=y
CONFIG_BRCMUTIL=y
CONFIG_BRCMSMAC=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_PCIE=y
# CONFIG_BRCM_TRACING is not set
# CONFIG_BRCMDBG is not set
CONFIG_WLAN_VENDOR_REALTEK=y
CONFIG_RTL_CARDS=y
CONFIG_RTL8192CE=y
CONFIG_RTL8192SE=y
CONFIG_RTL8192DE=y
CONFIG_RTL8723AE=y
CONFIG_RTL8723BE=y
CONFIG_RTL8188EE=y
CONFIG_RTL8192EE=y
CONFIG_RTL8821AE=y
# CONFIG_RTLWIFI_DEBUG is not set
CONFIG_RTW88=y
CONFIG_RTW88_8822BE=y
CONFIG_RTW88_8822CE=y
CONFIG_RTW88_8723DE=y
CONFIG_RTW88_8821CE=y
CONFIG_RTW88_8814AE=y
# CONFIG_RTW88_DEBUG is not set
# CONFIG_RTW88_DEBUGFS is not set
CONFIG_RTW89=y
CONFIG_RTW89_PCI=y
CONFIG_RTW89_8851BE=y
CONFIG_RTW89_8852AE=y
CONFIG_RTW89_8852BE=y
CONFIG_RTW89_8852BTE=y
CONFIG_RTW89_8852CE=y
CONFIG_RTW89_8922AE=y
# CONFIG_RTW89_DEBUGMSG is not set
# CONFIG_RTW89_DEBUGFS is not set
CONFIG_WLAN_VENDOR_MEDIATEK=y
CONFIG_MT7601U=y
CONFIG_MT76_CORE=y
CONFIG_MT76x02_LIB=y
CONFIG_MT76x0E=y
CONFIG_MT76x2E=y
CONFIG_MT76_CONNAC_LIB=y
CONFIG_MT7921_COMMON=y
CONFIG_MT7921E=y
CONFIG_MT7921U=y
CONFIG_MT7925_COMMON=y
CONFIG_MT7925E=y
CONFIG_WLAN_VENDOR_RALINK=y
CONFIG_RT2X00=y
CONFIG_RT2400PCI=y
CONFIG_RT2500PCI=y
CONFIG_RT61PCI=y
CONFIG_RT2800PCI=y
CONFIG_RT2800PCI_RT33XX=y
CONFIG_RT2800PCI_RT35XX=y
CONFIG_RT2800PCI_RT53XX=y
CONFIG_RT2800PCI_RT3290=y
# CONFIG_RT2X00_LIB_DEBUGFS is not set
# CONFIG_RT2X00_DEBUG is not set
CONFIG_WLAN_VENDOR_MARVELL=y
CONFIG_MWIFIEX=y
CONFIG_MWIFIEX_PCIE=y
CONFIG_CFG80211_INTERNAL_REGDB=y

# --- USB boot-media support. Keep explicit so the security-sensitive
#     ESP input-only/detach path does not depend on inherited distro
#     defconfig choices.
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_NVME=y
CONFIG_VMD=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PCI=y
CONFIG_MISC_RTSX_PCI=y
CONFIG_MISC_RTSX_USB=y
CONFIG_MMC_REALTEK_PCI=y
CONFIG_MMC_REALTEK_USB=y

# --- Serial console ---
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# --- Minimum filesystems + devtmpfs ---
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_EXT4_FS=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=y
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y

# --- Encrypted non-volatile storage ---
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_AES_NI_INTEL=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_SHA256=y

# --- Networking minimum ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_UNIX=y
CONFIG_PACKET=y
CONFIG_NETDEVICES=y

# --- initramfs support (need embed-friendly config) ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
# v1.2.1: zstd-compressed initramfs. With the aggressive slim in
# build-initramfs-hb.sh, zstd -19 is 30-40% smaller than gzip -1 at
# the same uncompressed corpus; kernel-side decompression is also
# faster than gzip on Ryzen-class CPUs. Both remain enabled so the
# build can ship either depending on which artefact the UKI uses.
CONFIG_RD_ZSTD=y

# --- Framebuffer console + native laptop display.
#
#     simpledrm remains the first-line fallback: it binds the firmware GOP
#     framebuffer and lets the splash draw even when no native GPU driver
#     claims the hardware. New laptop firmware is, however, uneven here: we
#     have seen blank-panel handoff failures on Meteor Lake Intel and Phoenix
#     AMD systems when relying on simpledrm alone.
#
#     The modern fix is `simpledrm': a minimal DRM driver that takes
#     the firmware framebuffer via SYSFB_SIMPLEFB. `fbcon' binds to
#     the DRM node, which keeps console output flowing through kernel
#     init. Works where efifb doesn't on Ryzen + Apple M-series
#     laptops, per upstream kernel commits a5e008f7b5c0 and friends.
#
#     Layered:
#       FB + FRAMEBUFFER_CONSOLE              -- fbcon text rendering
#       SYSFB + SYSFB_SIMPLEFB                -- firmware-fb platform dev
#       DRM + DRM_SIMPLEDRM + KMS_HELPER      -- DRM driver + KMS
#       DRM_FBDEV_EMULATION                   -- bridge to fbcon
#       FB_EFI                                -- fallback if SIMPLEDRM
#                                                doesn't probe
#       FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER -- hold efi stub output
#                                                until DRM is ready
#
#     We also build in the native open-source DRM drivers for the laptop
#     classes we care about:
#
#       i915       -- Intel Gen graphics up through Meteor Lake by default
#       xe         -- newer Intel Xe/Lunar/Battlemage path; available for
#                    force-probe experiments on Meteor Lake/Alchemist
#       amdgpu     -- AMD Ryzen/Radeon display path, including Phoenix
#
#     The drivers are open source, but they normally request vendor firmware
#     blobs at runtime. The Buildroot defconfig includes linux-firmware's
#     amdgpu, i915, and xe directories so those bytes are present and measured
#     by the firmware loader.
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DEFERRED_TAKEOVER=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_FBDEV_EMULATION=y

CONFIG_DRM_I915=y
CONFIG_DRM_XE=y
CONFIG_DRM_AMDGPU=y
# Keep optional GPU diagnostics and old-generation compatibility surfaces out
# unless a specific machine needs them.
# CONFIG_DRM_I915_CAPTURE_ERROR is not set
# CONFIG_DRM_I915_COMPRESS_ERROR is not set
# CONFIG_DRM_I915_USERPTR is not set
# CONFIG_DRM_I915_GVT is not set
# CONFIG_DRM_I915_GVT_KVMGT is not set
# CONFIG_DRM_I915_PXP is not set
# CONFIG_DRM_XE_DEBUG is not set
# CONFIG_DRM_XE_DEBUG_VM is not set
# CONFIG_DRM_XE_SIMPLE_ERROR_CAPTURE is not set
# CONFIG_DRM_AMDGPU_SI is not set
# CONFIG_DRM_AMDGPU_CIK is not set
# CONFIG_DRM_AMD_ACP is not set
# CONFIG_DRM_AMD_DC_FP is not set
# CONFIG_DRM_AMD_ISP is not set
# CONFIG_HSA_AMD is not set
# CONFIG_DRM_RADEON is not set
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_DRM_GMA500 is not set

# --- EDAC / RAS observational memory-controller reporting.
#
# These drivers expose read-only memory-controller state via
# /sys/devices/system/edac/mc where supported. The generic system device
# records that state for operator visibility, but it is not yet accepted as a
# security predicate: laptop LPDDR/DDR policy needs a narrower controller-backed
# probe before it becomes verifier-enforced evidence.
CONFIG_RAS=y
CONFIG_ACPI_APEI=y
CONFIG_ACPI_APEI_GHES=y
CONFIG_ACPI_APEI_MEMORY_FAILURE=y
# ACPI table contents are attestation evidence for LapEE. Keep runtime
# override paths out of the production kernel and expose the final kernel
# config read-only so ~system@1.0 can report that fact.
# CONFIG_ACPI_TABLE_UPGRADE is not set
# CONFIG_ACPI_CUSTOM_DSDT is not set
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_EDAC=y
# CONFIG_EDAC_DEBUG is not set
CONFIG_EDAC_DECODE_MCE=y
CONFIG_EDAC_GHES=y
CONFIG_EDAC_SCRUB=y
CONFIG_EDAC_ECS=y
CONFIG_EDAC_MEM_REPAIR=y
CONFIG_EDAC_AMD64=y
CONFIG_EDAC_IE31200=y
CONFIG_EDAC_SBRIDGE=y
CONFIG_EDAC_SKX=y
CONFIG_EDAC_I10NM=y
CONFIG_EDAC_IGEN6=y

# --- Attack-surface reduction — explicitly OFF ---
# Production LapEE is display-only. It accepts no local keyboard,
# mouse, touchpad, tablet, HID, I2C-HID, evdev, joystick, touchscreen,
# SysRq, or ACPI-button input. The only intended inputs after firmware
# selects the USB boot device are network packets to HyperBEAM.
CONFIG_EXPERT=y
# CONFIG_INPUT is not set
# CONFIG_INPUT_EVDEV is not set
# CONFIG_INPUT_KEYBOARD is not set
# CONFIG_KEYBOARD_ATKBD is not set
# CONFIG_INPUT_MOUSE is not set
# CONFIG_MOUSE_PS2 is not set
# CONFIG_INPUT_JOYSTICK is not set
# CONFIG_INPUT_TABLET is not set
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_INPUT_MISC is not set
# CONFIG_INPUT_LEDS is not set
# CONFIG_INPUT_FF_MEMLESS is not set
# CONFIG_INPUT_SPARSEKMAP is not set
# CONFIG_RFKILL_INPUT is not set
# CONFIG_SERIO is not set
# CONFIG_SERIO_I8042 is not set
# CONFIG_HID_SUPPORT is not set
# CONFIG_HID is not set
# CONFIG_HIDRAW is not set
# CONFIG_USB_HID is not set
# CONFIG_I2C_HID is not set
# CONFIG_VIRTIO_INPUT is not set
# CONFIG_MAC_EMUMOUSEBTN is not set
# CONFIG_ACPI_BUTTON is not set
# CONFIG_ACPI_VIDEO is not set
# CONFIG_ACPI_WMI is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_USB_MON is not set
# CONFIG_KEXEC is not set
# CONFIG_HIBERNATION is not set
# CONFIG_SUSPEND is not set
# CONFIG_DEBUG_FS is not set
CONFIG_X86_MSR=y
CONFIG_X86_CPUID=y
# CONFIG_DEVMEM is not set
# CONFIG_PROC_KCORE is not set
# CONFIG_MODULE_UNLOAD is not set
# CONFIG_BLK_DEV_IO_TRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_FTRACE is not set
# CONFIG_TRACING is not set
# CONFIG_TRACEFS_FS is not set

# --- Extra hardening ---
# Memory-safety compiler hardening
CONFIG_FORTIFY_SOURCE=y
CONFIG_HARDENED_USERCOPY=y
# Zero memory on alloc/free so use-before-init and use-after-free
# can't leak stale data — also reduces the value of any captured
# DRAM ciphertext for a TME-replay adversary (the "interesting"
# bytes are zeroed before/after the program holds them).
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
# Make slab/heap layout less exploitable.
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
# kASLR (kernel base + heap + memory regions). KASLR offsets the
# kernel image; RANDOMIZE_MEMORY randomises the relative offsets
# of physical-memory zones within the kernel's virtual map.
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
# Per-syscall kernel-stack offset randomisation (Cook 2019). Cheap.
CONFIG_RANDOMIZE_KSTACK_OFFSET=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y
# Shuffle the page allocator's free-lists so released physical
# pages don't return at predictable addresses on subsequent allocs.
# Direct mitigation against the TME-replay attack model documented
# in paper/beam-tagged-mac.tex: forces freed-and-reallocated
# pages to land at fresh physical addresses, so a captured
# ciphertext at a given physical address has limited reusability
# even after the kernel reclaims that page.
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
# Block raw /dev/mem reads over MMIO regions owned by drivers.
CONFIG_IO_STRICT_DEVMEM=y
# Don't let unsigned modules load, even at boot (vs. MODULE_SIG_ALL
# which only signs modules that happen to be built).
CONFIG_MODULE_SIG_FORCE=y
# Hide kernel pointers from dmesg for unprivileged users.
CONFIG_SECURITY_DMESG_RESTRICT=y
# IMA: appraise (refuse unsigned files) on top of the measurement
# we already do. Needs a signed policy and a trusted keyring at
# runtime; configured here so the kernel CAN enforce if userspace
# asks for it.
CONFIG_IMA_APPRAISE=y
CONFIG_IMA_APPRAISE_BOOTPARAM=y
CONFIG_INTEGRITY_TRUSTED_KEYRING=y
# Non-debug kernel in production.
# CONFIG_DEBUG_KERNEL is not set
