# Dedicated Secure Boot setup-mode provisioning image.
#
# Production LapEE images deliberately do not expose EFI-variable write
# tooling. This variant needs efivarfs so PID 1 can enroll the operator's
# public PK/KEK/db bundle on firmware that has no key-management UI.
CONFIG_EFIVAR_FS=y

# The provisioner is intentionally not the production appliance. It needs a
# single local keyboard confirmation before writing EFI variables.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_HID_SUPPORT=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_I2C_HID=y
CONFIG_I2C_HID_ACPI=y
CONFIG_VIRTIO_INPUT=y
