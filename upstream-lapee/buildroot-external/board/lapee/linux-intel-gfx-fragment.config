# linux-intel-gfx-fragment.config -- native Intel display fallback.
#
# Debug/compatibility only. This enables the smallest useful Intel
# kernel modesetting path for laptops whose firmware framebuffer stops
# updating after the EFI stub handoff. i915 is intentionally not in the
# hardened production fragment: its Kconfig selects ACPI/input helpers
# that widen the local-machine surface.
CONFIG_DRM_I915=y
CONFIG_DRM_I915_FORCE_PROBE="*"

# Keep optional i915 diagnostics and virtualisation surfaces out of this
# compatibility image unless we specifically need them.
# CONFIG_DRM_I915_CAPTURE_ERROR is not set
# CONFIG_DRM_I915_COMPRESS_ERROR is not set
# CONFIG_DRM_I915_USERPTR is not set
# CONFIG_DRM_I915_GVT is not set
# CONFIG_DRM_I915_GVT_KVMGT is not set
# CONFIG_DRM_I915_PXP is not set
