#!/bin/sh
# lapee-dhcp-hook -- udhcpc action script. Called by udhcpc on
# deconfig / bound / renew / nak / leasefail events. Busybox's
# udhcpc passes state via $1 (action) and the lease as env vars
# (ip, subnet, router, dns, lease).
#
# Policy: the FIRST interface to get a lease wins and becomes the
# default route; later interfaces keep their IP for diagnostics
# but do NOT overwrite the default. This implements the v1.2
# precedence spec: whichever wired interface appears first with
# carrier gets promoted; later (or slower) ones stay in the
# background. iproute2 accepts a dotted-decimal subnet mask
# directly (`ip addr add 1.2.3.4/255.255.255.0'), which keeps
# this hook small + dependency-free.

set -eu
: "${interface:=unknown}"

PRIMARY=/run/lapee/primary-net
STATUS=/run/lapee/status
mkdir -p /run/lapee

status() {
    printf '%s\n' "$*" > "$STATUS" 2>/dev/null || true
}

log_net() {
    _msg="$*"
    echo "$_msg"
    if [ "${LAPEE_DEBUG:-0}" = "1" ]; then
        printf '%s\n' "$_msg" > /dev/console 2>/dev/null || true
        printf '<6>[lapee-dhcp] %s\n' "$_msg" > /dev/kmsg 2>/dev/null || true
    fi
}

primary_iface() {
    sed -n 's/^iface=//p' "$PRIMARY" 2>/dev/null | sed -n '1p'
}

status_if_no_primary() {
    if [ ! -s "$PRIMARY" ]; then
        status "$@"
    else
        log_net "[net] $interface: status unchanged; primary $(primary_iface) is already up"
    fi
}

case "${1:-unknown}" in
    deconfig)
        ip -4 addr flush dev "$interface" 2>/dev/null || true
        ip link set "$interface" up 2>/dev/null || true
        status_if_no_primary "Requesting a network address on $interface."
        log_net "[net] $interface: deconfig"
        ;;

    bound|renew)
        if [ -z "${ip:-}" ]; then
            log_net "[net] $interface: bound event without ip= -- skipping"
            exit 0
        fi
        mask=${subnet:-255.255.255.0}
        ip -4 addr flush dev "$interface" 2>/dev/null || true
        ip -4 addr add "$ip/$mask" dev "$interface" \
            2>/dev/null || true
        ip link set "$interface" up 2>/dev/null || true

        if [ ! -s "$PRIMARY" ]; then
            # Only claim the primary slot if DHCP actually gave us
            # a default gateway. Some networks (hotel captive
            # portals, 802.1x walled gardens) hand out an IP with
            # no router option. Writing to PRIMARY here would
            # block any subsequent interface from becoming the
            # real default, so we leave the slot empty and log
            # that the lease is ip-only (useful data for
            # diagnostics, not promoted to primary).
            if [ -z "${router:-}" ]; then
                status "Got an address on $interface, but no gateway."
                log_net "[net] $interface: bound ip=$ip" \
                        "NO-GATEWAY (ip-only; not promoting to primary)"
            else
                for gw in ${router:-}; do
                    ip -4 route replace default via "$gw" \
                        dev "$interface" 2>/dev/null || true
                done
                if [ -n "${dns:-}" ]; then
                    : > /etc/resolv.conf || true
                    for n in $dns; do
                        echo "nameserver $n" >> /etc/resolv.conf
                    done
                fi
                printf "iface=%s\nip=%s\ngw=%s\ndns=%s\n" \
                    "$interface" "$ip" "${router:-}" \
                    "${dns:-}" > "$PRIMARY"
                status "Network is up on $interface."
                log_net "[net] $interface: bound ip=$ip" \
                        "gw=${router:-} dns=${dns:-none}  (primary)"
                # No console-side banner. The BEAM splash polls
                # /run/lapee/primary-net for the IP and the dev_tpm2
                # /info endpoint for HB readiness; it owns the
                # phase machine itself.
            fi
        else
            log_net "[net] $interface: bound ip=$ip  (secondary;" \
                    "keeping default route from $(cat "$PRIMARY" \
                        | sed -n 's/^iface=//p'))"
        fi
        ;;

    nak|leasefail)
        if [ -s "$PRIMARY" ]; then
            log_net "[net] $interface: $1 (no lease; primary $(primary_iface) already up)"
        else
            status "Still waiting for a network address on $interface."
            log_net "[net] $interface: $1 (no lease)"
        fi
        ;;

    *)
        ;;
esac

exit 0
