# Memory-encryption gate (paper P2).
#
# Intel TME is firmware-configured before Linux starts. The kernel's
# early Intel probe reads IA32_TME_ACTIVATE and emits one of the useful
# states we care about:
#
#   x86/tme: enabled by BIOS
#   x86/tme: not enabled by BIOS
#
# Prefer that evidence over a raw `/proc/cpuinfo' flag. CPU flags alone
# can only say "advertised"; the kernel log distinguishes "advertised
# but firmware left it off" from "actually enabled". AMD SME is still
# handled as a capability flag for now; the shipped v1 target is Intel-
# focused and the verifier reports the final posture separately.
#
# Operator override: `LAPEE_NO_TME=1' on the cmdline skips the gate.
# The override is measured into PCR 4/8 via the UKI cmdline, so any
# attestation carries it. This is intentionally allowed in production
# images for hardware-compatibility testing; verifier policy must treat
# such boots as non-memory-encrypted.
check_tme_sme() {
    if cmdline_flag_set LAPEE_NO_TME; then
        status "Memory-encryption check skipped for this boot."
        trace "tme: LAPEE_NO_TME=1 on cmdline; skipping enforcement"
        return 0
    fi
    # Developer bypass: QEMU / KVM / Xen / VMware / VirtualBox
    # guests can't expose TME/SME to Rosetta-emulated amd64, so
    # make qemu smoke-boot would otherwise halt at this
    # gate. Auto-detect via DMI sys_vendor and skip enforcement
    # WITH a clear trace so the bypass is visible in logs + any
    # attestation captured from that guest shows the virt-vendor
    # in its platform-probes. Physical Framework 13 reads
    # "Framework" here, never "QEMU".
    _dmi_vendor=$(cat /sys/class/dmi/id/sys_vendor 2>/dev/null \
        | tr -d '\r\n' || echo '')
    case "$_dmi_vendor" in
        QEMU|"Bochs"|"Xen"|"VMware, Inc."|"innotek GmbH"|"Microsoft Corporation")
            status "Virtual machine detected; skipping hardware memory-encryption check."
            trace "tme: virt host detected (dmi sys_vendor='$_dmi_vendor'); paper P2 enforcement applies only to physical silicon -- proceeding"
            return 0
            ;;
    esac

    _tme_log=$(dmesg 2>/dev/null | grep -Ei 'x86/(tme|mktme)' || true)
    if [ -n "$_tme_log" ]; then
        printf '%s\n' "$_tme_log" | while IFS= read -r _line; do
            trace "tme-kernel: $_line"
        done
    fi
    case "$_tme_log" in
        *"x86/tme: enabled by BIOS"*)
            trace "tme: kernel confirmed Intel TME enabled"
            status "Memory encryption is enabled."
            return 0
            ;;
        *"x86/tme: not enabled by BIOS"*)
            trace "tme: Intel TME advertised but firmware did not enable it"
            halt_boot "Memory encryption is supported, but firmware has not enabled TME."
            ;;
    esac

    _cpuflags=$(awk '/^flags[^:]*:/ {$1=""; $2=""; print; exit}' \
        /proc/cpuinfo 2>/dev/null)
    _has_cap=no
    case " $_cpuflags " in
        *" tme "*) _has_cap=tme ;;
        *" sme "*) _has_cap=sme ;;
    esac
    case "$_has_cap" in
        tme)
            trace "tme: CPU advertises TME, but kernel did not confirm enablement"
            halt_boot "TME is advertised, but the kernel did not confirm that firmware enabled it."
            ;;
        sme)
            trace "tme: AMD SME capability present -> proceed"
            status "Memory-encryption capability is present."
            return 0
            ;;
        *)
            trace "tme: CPU/firmware did not advertise tme/sme in /proc/cpuinfo"
            trace "tme: (operator override with LAPEE_NO_TME=1 on cmdline)"
            halt_boot "Memory encryption is not advertised by this CPU or firmware."
            ;;
    esac
}
check_tme_sme

